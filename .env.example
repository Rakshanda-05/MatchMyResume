# ─── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ─── Required: Anthropic API ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Required: Twilio WhatsApp ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox number

# ─── App Configuration ────────────────────────────────────────────────────────
# Public URL of your server (used for resume download links)
# For local testing with ngrok: https://abc123.ngrok.io
BASE_URL=http://localhost:8000

# Session timeout in minutes (how long to keep user conversation state)
SESSION_TTL_MINUTES=60

# Max resume file size in MB
MAX_FILE_SIZE_MB=10

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514
